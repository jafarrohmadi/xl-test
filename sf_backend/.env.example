# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sf_backend_db?sslmode=disable

# Server Configuration
PORT=8081
ENV=development

# Service URLs (for inter-service communication)
SF_PAYMENT_URL=http://localhost:8082
PARTNER_URL=http://localhost:8083

# Security
JWT_SECRET=your-jwt-secret-key-change-in-production
HMAC_SECRET=your-hmac-secret-key-change-in-production

# Timeouts
HTTP_TIMEOUT=30s
DB_TIMEOUT=10s

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.xlsmart.co.id
